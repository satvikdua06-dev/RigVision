# ──────────────────────────────────────────
# RigVision-3D .gitignore
# ──────────────────────────────────────────

# ── Environment & Secrets ──
# NEVER commit API keys, passwords, or .env files
.env
.env.local
.env.production

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
*.pyc
*.pyo
*.pyd
.Python

# ── Node.js ──
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── ML Model Weights ──
# These are large binary files — download on setup, don't commit
cv/models/*.pt
cv/models/*.onnx
cv/models/*.engine
*.pt
*.onnx

# ── Calibration outputs (contain camera-specific data) ──
cv/calibration/configs/*.json

# ── Video files (too large for git) ──
*.mp4
*.avi
*.mkv
test_videos/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Docker ──
docker-compose.override.yml

# ── Logs ──
*.log
logs/

# ── Database files ──
*.db
*.sqlite3
