# ------------------------------------------------
# RigVision Environment Variables
# ------------------------------------------------
# Copy this file to .env and fill in your actual values.
# The .env file is ignored by git to keep secrets safe.

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── PostgreSQL + TimescaleDB ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rigvision
POSTGRES_USER=rigvision
POSTGRES_PASSWORD=rigvision_dev_password

# ── Neo4j (Knowledge Graph) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rigvision_neo4j

# ── Kafka (Message Broker) ──
KAFKA_BROKER=localhost
KAFKA_PORT=9092

# ── Camera RTSP URLs (DroidCam on phones) ──
# Replace with your phone IPs after installing DroidCam
CAMERA_0_URL=rtsp://192.168.1.101:4747/video
CAMERA_1_URL=rtsp://192.168.1.102:4747/video
CAMERA_2_URL=rtsp://192.168.1.103:4747/video

# ── YOLO Model ──
# Options: yolov8n.pt (fast/CPU), yolov8l.pt (accurate/GPU)
YOLO_MODEL=yolov8l.pt
YOLO_CONFIDENCE=0.5

# ── PPE Detection demo (cv/ppe_demo.py) ──
# Open Images V7 model (has Glasses/Sunglasses/Hat/Person classes, no fine-tune).
PPE_MODEL=yolov8x-oiv7.pt
PPE_INFERENCE_IMGSZ=1280
PPE_CONFIDENCE=0.1            # PPE-item confidence (kept low; debounce smooths noise)
PPE_PERSON_CONFIDENCE=0.3     # Person-class confidence used for gating
PPE_DETECT_SECONDS=3.0        # continuous-seconds before a status is committed
PPE_PROOF_DIR=cv/ppe_proof    # where "missing" proof frames are saved
PPE_CAMERA_INDEX=0            # webcam index for the standalone demo (cv/ppe_demo.py)
# When folded into the main pipeline (cv/pipeline.py):
PPE_ENABLED=1                # set 0 to disable PPE inside the pipeline
PPE_CAMERA_IDS=0             # cameras to judge PPE on, comma list (e.g. "0,1" for 2 feeds);
                             #   a person shows DETECTED if ANY listed feed sees the item
PPE_EVERY_N_FRAMES=3         # run PPE every Nth pipeline tick (keeps FPS up)

# ── LLM API Keys (Phase 7) ──
# Gemini is still used for EMBEDDINGS (RAG retrieval) in the diagnostic agent.
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Answer-generation LLM (local LM Studio, OpenAI-compatible REST) ──
# Start the server in LM Studio's Developer tab. Confirm LLM_MODEL via:
#   GET http://localhost:1234/v1/models
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-4-12b-qat

# ── FastAPI ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ──
VITE_WS_URL=ws://localhost:8000/ws/realtime
VITE_API_URL=http://localhost:8000/api

# --- Kafka Topics ---
# Used by anomaly_listener.py
KAFKA_TOPIC_ALERTS=rigvision_alerts
KAFKA_TOPIC_DIAGNOSTICS=rigvision_diagnostics