# ------------------------------------------------
# RigVision Environment Variables
# ------------------------------------------------
# Copy this file to .env and fill in your actual values.
# The .env file is ignored by git to keep secrets safe.

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── PostgreSQL + TimescaleDB ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=rigvision
POSTGRES_USER=rigvision
POSTGRES_PASSWORD=rigvision_dev_password

# ── Neo4j (Knowledge Graph) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rigvision_neo4j

# ── Kafka (Message Broker) ──
KAFKA_BROKER=localhost
KAFKA_PORT=9092

# ── Camera RTSP URLs (DroidCam on phones) ──
# Replace with your phone IPs after installing DroidCam
CAMERA_0_URL=rtsp://192.168.1.101:4747/video
CAMERA_1_URL=rtsp://192.168.1.102:4747/video
CAMERA_2_URL=rtsp://192.168.1.103:4747/video

# ── YOLO Model ──
# Options: yolov8n.pt (fast/CPU), yolov8l.pt (accurate/GPU)
YOLO_MODEL=yolov8l.pt
YOLO_CONFIDENCE=0.5

# ── PPE Detection (EfficientNet-B0 binary classifiers) ──
# Backend: yolov8n-face → padded face crop → EfficientNet-B0 per item.
# Models live in cv/PPE/models/. Retrain with cv/PPE/train_classifier.py.
#
# Face-detection crop (PAD_TOP=0.3 matches training data from generate_caps_celeba.py).
PPE_FACE_MODEL_PATH=          # leave empty to auto-download yolov8n-face.pt from HuggingFace
                              # or set to a local .pt path to skip the download (faster startup)
PPE_FACE_CONFIDENCE=0.5      # yolov8n-face detection threshold
PPE_FACE_PAD_TOP=0.3         # padding above face (×face height) — captures cap crown
PPE_FACE_PAD_BOTTOM=0.1      # padding below face
PPE_FACE_PAD_LEFT=0.2        # padding left/right — captures glasses temples
PPE_FACE_PAD_RIGHT=0.2
#
# Classifier model dirs (defaults point at cv/PPE/models/ — override to use custom checkpoints)
PPE_CAP_MODEL_DIR=            # default: cv/PPE/models/cap_classifier
PPE_GLASSES_MODEL_DIR=        # default: cv/PPE/models/glasses_classifier
#
# Detection thresholds — hysteresis (Schmitt-trigger) to avoid hair false-positives
# while still detecting a hat quickly:
#
#   ONSET  (no hat → hat): short fast buffer (FAST_WINDOW frames) vs CONFIRM threshold.
#          Hair averages ~0.7 → safely below 0.97; a real hat (~0.99) trips in 1-2 frames.
#   HOLD   (hat → no hat): long slow buffer (SCORE_WINDOW frames) vs MAINTAIN threshold.
#          Brief occlusions / lighting dips don't flip back to "missing".
#
PPE_CAP_THRESHOLD=0.97           # onset confirm threshold (high — rejects hair)
PPE_CAP_MAINTAIN_THRESHOLD=0.55  # hold threshold once "detected"
PPE_CAP_FAST_WINDOW=10           # short onset buffer; 10f ≈ 0.33s at 30fps
PPE_GLASSES_THRESHOLD=0.5
PPE_GLASSES_MAINTAIN_THRESHOLD=0.35
PPE_GLASSES_FAST_WINDOW=10
PPE_SCORE_WINDOW=90              # slow hold buffer; 90f ≈ 3s at 30fps
PPE_DETECT_SECONDS=3.0           # debounce: hold for this long before committing a status flip
#
# Person gating and head-crop fallback (used when no face is detected)
PPE_PERSON_CONFIDENCE=0.3    # YOLOv8l person-class score threshold
PPE_HEAD_REGION=0.5          # top fraction of person box (geometric fallback crop)
PPE_HEAD_PAD_X=0.2
PPE_HEAD_PAD_TOP=0.18
#
# Pipeline integration
PPE_PROOF_DIR=cv/ppe_proof    # where "missing PPE" evidence frames are saved
PPE_CAMERA_INDEX=0            # webcam index for standalone demo (cv/ppe_demo.py)
PPE_ENABLED=1                 # set to 0 to disable PPE inside cv/pipeline.py
PPE_CAMERA_IDS=0              # cameras checked for PPE, comma-separated (e.g. "0,1")
PPE_EVERY_N_FRAMES=3          # run PPE every Nth pipeline frame (saves GPU headroom)

# ── CV Pipeline Tuning ──
REPROJ_THRESHOLD=60.0        # reprojection error gate (px); raise if calibration is noisy
DISPLAY_FPS=30               # target render FPS for the 3D frontend (Zustand fpsLimit)
SENSOR_STALE_SECONDS=30      # MQTT sensor readings expire after this many seconds (source:"mqtt" only)

# ── LLM API Keys (Phase 7) ──
# GEMINI_API_KEY is no longer required for diagnostics (embeddings are local now).
# Kept only if other tooling still uses it.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Answer-generation LLM (local LM Studio, OpenAI-compatible REST) ──
# Start the server in LM Studio's Developer tab. Confirm LLM_MODEL via:
#   GET http://localhost:1234/v1/models
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-4-12b-qat

# ── Embeddings LLM (local LM Studio, OpenAI-compatible /v1/embeddings) ──
# Used for RAG retrieval (rag_ingestion.py + diagnostic_agent). Load an embedding
# model in LM Studio and confirm the id via GET {EMBED_BASE_URL}/models.
# IMPORTANT: changing EMBED_MODEL requires re-running rag_ingestion.py (the
# ChromaDB collection stores vectors of a single dimensionality).
# Defaults reuse the generation server if these are unset.
EMBED_BASE_URL=http://localhost:1234/v1
EMBED_API_KEY=lm-studio
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# ── FastAPI ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── API auth + rate limiting ──
# Shared secret for mutating endpoints (POST /api/sensors, /api/diagnostics/run,
# /api/diagnostics/clear, /api/thresholds/refresh, /api/control/clear_cache).
# Leave EMPTY to disable auth (dev). When set, the frontend must send the same
# value as VITE_API_KEY (see Frontend section).
RIGVISION_API_KEY=
# Minimum seconds between explicit RUN DIAGNOSTICS calls (debounces LLM spam).
DIAGNOSTICS_MIN_INTERVAL=2.0

# ── Frontend ──
VITE_WS_URL=ws://localhost:8000/ws/realtime
VITE_API_URL=http://localhost:8000/api
# Must match RIGVISION_API_KEY above when auth is enabled (leave empty in dev).
VITE_API_KEY=

# --- Kafka Topics ---
# Used by anomaly_listener.py
KAFKA_TOPIC_ALERTS=rigvision_alerts
KAFKA_TOPIC_DIAGNOSTICS=rigvision_diagnostics
# How many alerts the listener diagnoses concurrently (thread pool).
LISTENER_WORKERS=3

# ── SCADA Gateway ──
# Reconciler checks config files every N seconds; hot-adds/removes port workers.
SCADA_RECONCILE_INTERVAL=5
# Publisher batches up to N readings or waits this many ms before flushing.
SCADA_BATCH_SIZE=20
SCADA_BATCH_MAX_WAIT_MS=500
# MQTT simulator settings (scada/simulators/mqtt_publisher.py)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_SIM_INTERVAL=1.0

# ── JWT (auth-rig) ──
# SECURITY: use placeholder values here; put real secrets in .env only.
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here