# ------------------------------------------------
# RigVision Environment Variables
# ------------------------------------------------
# Copy this file to .env and fill in your actual values.
# The .env file is ignored by git to keep secrets safe.

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── PostgreSQL + TimescaleDB ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rigvision
POSTGRES_USER=rigvision
POSTGRES_PASSWORD=rigvision_dev_password

# ── Neo4j (Knowledge Graph) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rigvision_neo4j

# ── Kafka (Message Broker) ──
KAFKA_BROKER=localhost
KAFKA_PORT=9092

# ── Camera RTSP URLs (DroidCam on phones) ──
# Replace with your phone IPs after installing DroidCam
CAMERA_0_URL=rtsp://192.168.1.101:4747/video
CAMERA_1_URL=rtsp://192.168.1.102:4747/video
CAMERA_2_URL=rtsp://192.168.1.103:4747/video

# ── YOLO Model ──
# Options: yolov8n.pt (fast/CPU), yolov8l.pt (accurate/GPU)
YOLO_MODEL=yolov8l.pt
YOLO_CONFIDENCE=0.5

# ── LLM API Keys (Phase 7) ──
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── FastAPI ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ──
VITE_WS_URL=ws://localhost:8000/ws/realtime
VITE_API_URL=http://localhost:8000/api

# --- Kafka Topics ---
# Used by anomaly_listener.py
KAFKA_TOPIC_ALERTS=rigvision_alerts
KAFKA_TOPIC_DIAGNOSTICS=rigvision_diagnostics